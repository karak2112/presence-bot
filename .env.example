# Twitch Developer App — https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# SMTP (Gmail: use an app password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

# Optional overrides
POLL_INTERVAL_SECONDS=60
WATCHDOG_INTERVAL_SECONDS=600
HEALTH_PORT=8080
BROWSER_ENABLED=true
LOG_LEVEL=INFO
POINTS_LOG_INTERVAL_SECONDS=900
FILE_LOG_ENABLED=true
DROPS_ENABLED=true
DROPS_POLL_INTERVAL_SECONDS=180
